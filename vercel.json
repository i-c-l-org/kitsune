{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm ci --include=dev",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["gru1"],
  "rewrites": [
    {
      "source": "/api/github-traffic/:path*",
      "destination": "/api/github-traffic/:path*"
    }
  ],
  "routes": [
    {
      "src": "/api/:path*",
      "has": [
        {
          "type": "query",
          "key": "svg",
          "value": ".*.*"
        }
      ]
    }
  ],

  "headers": [
    {
      "source": "/api/github-traffic/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}
